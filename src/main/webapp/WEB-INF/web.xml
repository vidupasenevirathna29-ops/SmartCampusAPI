<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Smart Campus API</display-name>

    <!--
        Register Jersey's ServletContainer and point it at our Application subclass.
        @ApplicationPath("/api/v1") on SmartCampusApplication provides the JAX-RS
        standard annotation. The servlet-mapping below explicitly tells Tomcat to
        route /api/v1/* to Jersey.
    -->
    <servlet>
        <servlet-name>SmartCampusServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>com.smartcampus.SmartCampusApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SmartCampusServlet</servlet-name>
        <!-- Matches /api/v1/ and all sub-paths -->
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
